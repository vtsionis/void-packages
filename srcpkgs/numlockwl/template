# Template file for 'numlockwl'
pkgname=numlockwl
version=1.0
revision=1
makedepends="libevdev-devel"
short_desc="Enable NumLock on startup"
maintainer="Vasileios Tsionis <tsionisvasileios@protonmail.com>"
license="MIT"
homepage="https://github.com/jeebuscrossaint/numlockwl"
distfiles="https://github.com/jeebuscrossaint/numlockwl/archive/refs/heads/main.zip"
