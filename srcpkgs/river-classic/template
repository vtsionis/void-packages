# Template file for 'river-classic'
pkgname=river-classic
version=0.3.17
revision=1
conflicts="river"
archs="~i686* ~armv6l* ~armv7l*"
hostmakedepends="pkg-config zig16 wayland-devel scdoc"
makedepends="wayland-devel wayland-protocols wlroots0.20-devel libxkbcommon-devel
 libevdev-devel pixman-devel"
depends="xorg-server-xwayland"
short_desc="Dynamic tiling Wayland compositor"
maintainer="Vasileios Tsionis <tsionisvasileios@protonmail.com>"
license="GPL-3.0-only"
homepage="https://codeberg.org/river/river-classic"
distfiles="https://codeberg.org/river/river-classic/releases/download/v${version}/river-classic-${version}.tar.gz"
checksum=ecd5e632a417b1d79e23180bf0073c8d8f849180ebb9138e5fa71ec8bfe15fdd

do_build() {
    zig16 build -Doptimize=ReleaseSafe -Dxwayland=true
}

post_build() {
    mkdir -p zig-out/man
	scdoc < doc/river.1.scd > zig-out/man/river.1
	scdoc < doc/riverctl.1.scd > zig-out/man/riverctl.1
	scdoc < doc/rivertile.1.scd > zig-out/man/rivertile.1
}

do_install() {
    vbin zig-out/bin/river
    vbin zig-out/bin/riverctl
    vbin zig-out/bin/rivertile
}

post_install() {
	vinstall contrib/river.desktop 644 usr/share/wayland-sessions

	vsconf example/init

    vman zig-out/man/river.1
    vman zig-out/man/riverctl.1
    vman zig-out/man/rivertile.1

	vlicense LICENSE
}
